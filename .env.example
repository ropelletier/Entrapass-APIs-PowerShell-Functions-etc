# =============================================================================
# Kantech EntraPass - Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Advantage Database (EntraPass)
# Default paths match a standard EntraPass CE install — only change these
# if your installation directory is non-standard.
# -----------------------------------------------------------------------------
KANTECH_DATA_DIR=C:\Program Files (x86)\Kantech\Server_CE\Data
KANTECH_ARCHIVE_DIR=C:\Program Files (x86)\Kantech\Server_CE\Archive
KANTECH_ASQLCMD=C:\Program Files (x86)\Advantage 12.0\ARC\asqlcmd.exe
KANTECH_OPERATOR_USER=your_operator_username
KANTECH_OPERATOR_PASSWORD=change_me

# -----------------------------------------------------------------------------
# MySQL - Remote database
# -----------------------------------------------------------------------------
MYSQL_HOST=192.168.1.100
MYSQL_PORT=3306
MYSQL_DATABASE=kantech
MYSQL_USER=kantech_user
MYSQL_PASSWORD=change_me

# -----------------------------------------------------------------------------
# Card export (Export-KantechCards.ps1 / Register-NightlyExport.ps1)
# EXPORT_RUN_TIME: 24h format, e.g. 02:00 = 2 AM
# EXPORT_RETAIN_DAYS: days to keep old CSV files (0 = keep forever)
# -----------------------------------------------------------------------------
EXPORT_OUTPUT_DIR=C:\Exports\Kantech
EXPORT_RETAIN_DAYS=30
EXPORT_RUN_TIME=02:00

# -----------------------------------------------------------------------------
# Monitor service (Watch-Kantech.ps1 / Install-KantechEventService.ps1)
# EVENT_POLL_SECONDS: how often to check for new events (min 1, recommended 5)
# -----------------------------------------------------------------------------
EVENT_POLL_SECONDS=5
EVENT_LOG_DIR=C:\Exports\Kantech

# Enable/disable individual monitors (set to false to disable)
MONITOR_DOOR_EVENTS=true
MONITOR_DOOR_ALARMS=true
MONITOR_AFTER_HOURS=true
MONITOR_REPEATED_DENIALS=true

# -----------------------------------------------------------------------------
# Email alerts (no-auth SMTP)
# SMTP_TO: comma-separated list of recipients
# ALERT_HOURS_START / ALERT_HOURS_END: business hours in HH:MM (24h)
# ALERT_DENIAL_COUNT: denials within window to trigger alert
# ALERT_DENIAL_WINDOW_MINUTES: rolling window for repeated denial check
# -----------------------------------------------------------------------------
SMTP_HOST=192.168.1.1
SMTP_PORT=25
SMTP_FROM=kantech-alerts@school.org
SMTP_TO=admin@school.org

ALERT_HOURS_START=06:00
ALERT_HOURS_END=21:00
ALERT_DENIAL_COUNT=3
ALERT_DENIAL_WINDOW_MINUTES=15
